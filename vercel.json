{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server.js"
        },
        {
            "src": "/admin/login",
            "dest": "public/admin-login.html"
        },
        {
            "src": "/(.*)",
            "dest": "public/$1"
        }
    ]
}